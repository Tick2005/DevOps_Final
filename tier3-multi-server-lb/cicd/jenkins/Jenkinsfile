pipeline {
  agent any

  environment {
    BUILD_CONTAINER = 'false'
    IMAGE_TAG = "${env.GIT_COMMIT}"
  }

  stages {
    stage('Checkout') {
      steps {
        checkout scm
      }
    }

    stage('Install') {
      steps {
        dir('tier3-multi-server-lb/backend') {
          sh 'npm ci'
        }
      }
    }

    stage('Lint') {
      steps {
        dir('tier3-multi-server-lb/backend') {
          sh 'npm run lint --if-present'
        }
      }
    }

    stage('Build') {
      steps {
        dir('tier3-multi-server-lb/backend') {
          sh 'npm run build --if-present'
          sh 'tar -czf ../../app-artifact.tgz .'
        }
      }
    }

    stage('Security Scan') {
      steps {
        sh 'trivy fs --exit-code 1 --severity HIGH,CRITICAL tier3-multi-server-lb/backend'
      }
    }

    stage('Build and Push Image') {
      when {
        expression { env.BUILD_CONTAINER == 'true' }
      }
      steps {
        sh 'echo Set registry login here'
        sh 'docker build -t your-registry/final-app:${IMAGE_TAG} tier3-multi-server-lb/backend'
        sh 'docker push your-registry/final-app:${IMAGE_TAG}'
      }
    }

    stage('Deploy') {
      steps {
        sh 'chmod +x tier3-multi-server-lb/deployment/app-node-deploy.sh'
        sh 'tier3-multi-server-lb/deployment/app-node-deploy.sh'
      }
    }
  }
}

apiVersion: v1
kind: Secret
metadata:
  name: mongodb-secret
  namespace: startupx
type: Opaque
data:
  # Base64 encoded values
  # To encode: echo -n 'your-value' | base64
  # To decode: echo 'encoded-value' | base64 -d
  
  # Example: admin (YWRtaW4=)
  mongodb-root-username: YWRtaW4=
  
  # Example: password123 (cGFzc3dvcmQxMjM=)
  mongodb-root-password: cGFzc3dvcmQxMjM=
  
  # Database name: startupx (c3RhcnR1cHg=)
  mongodb-database: c3RhcnR1cHg=

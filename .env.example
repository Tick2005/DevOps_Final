# =============================================================================
# .ENV.EXAMPLE - Cấu hình môi trường cho DevOps Final Project
# =============================================================================
# Copy file này thành .env và điền các giá trị thực tế
# =============================================================================

# =============================================================================
# AWS CONFIGURATION
# =============================================================================
# Tên SSH Key đã tạo trên AWS Console (KHÔNG có đuôi .pem)
# File .pem phải nằm trong thư mục gốc project
AWS_KEY_NAME=your-key-name-here

# AWS Region để deploy (khuyến nghị: ap-southeast-1 cho Singapore)
AWS_REGION=ap-southeast-1

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
# Password cho PostgreSQL (dùng cho cả Production và Staging)
# Password này sẽ được dùng để:
# - Tạo user PostgreSQL trên DB server
# - Cấu hình trong GitHub Actions Secret DB_PASSWORD
DB_PASSWORD=SecurePassword123!

# Database names
DB_NAME_PROD=productx_db
DB_NAME_STAGING=productx_db_staging

# Database users
DB_USER_PROD=productx_user
DB_USER_STAGING=productx_staging_user

# =============================================================================
# SONARQUBE CONFIGURATION (Self-hosted, miễn phí hoàn toàn)
# =============================================================================
# URL của SonarQube server (sau khi deploy bằng Ansible)
# Format: http://<SONARQUBE_PUBLIC_IP>:9000
SONAR_HOST_URL=http://your-sonarqube-ip:9000

# Project key tạo trong SonarQube (VD: productx-backend)
SONAR_PROJECT_KEY=productx-backend

# Token tạo trong SonarQube (Administration → Security → Users → Tokens)
SONAR_TOKEN=your-sonar-token

# =============================================================================
# DOCKER HUB CONFIGURATION
# =============================================================================
DOCKER_USERNAME=your-dockerhub-username

# =============================================================================
# DOMAIN & HTTPS (Optional - để trống nếu chưa có domain)
# =============================================================================
# Domain name của bạn (VD: example.com)
DOMAIN_NAME=

# Bật HTTPS (true/false)
ENABLE_HTTPS=false

# =============================================================================
# MONITORING & ALERTING (Optional)
# =============================================================================
# Email để nhận alerts từ Prometheus Alertmanager
ALERT_EMAIL=

# Gmail App Password (tạo tại: https://myaccount.google.com/apppasswords)
# Yêu cầu: Bật 2-Step Verification trước
# ⚠️ XÓA TẤT CẢ KHOẢNG TRẮNG! (VD: abcdefghijklmnop)
ALERT_EMAIL_PASSWORD=

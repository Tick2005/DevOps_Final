# =============================================================================
# HOSTS.INI.EXAMPLE - Ansible Inventory
# =============================================================================
# Copy file này thành hosts.ini và điền IP addresses từ Terraform output
# =============================================================================

[database]
# Database + NFS Server (cùng 1 EC2 instance)
db-server ansible_host=REPLACE_WITH_DATABASE_PUBLIC_IP ansible_user=ubuntu

[nfs_server]
# NFS Server (cùng server với database)
db-server ansible_host=REPLACE_WITH_DATABASE_PUBLIC_IP ansible_user=ubuntu

[sonarqube]
# SonarQube Server (EC2 instance riêng)
sonar-server ansible_host=REPLACE_WITH_SONARQUBE_PUBLIC_IP ansible_user=ubuntu

[all:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_ssh_common_args='-o StrictHostKeyChecking=no'

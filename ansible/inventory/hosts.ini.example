# =============================================================================
# ANSIBLE INVENTORY - ProductX Infrastructure
# =============================================================================
# File này là template, file thực sẽ được generate bởi GitHub Actions
# Hoặc tạo thủ công khi chạy local
# =============================================================================

[database]
db-server ansible_host=<DB_PUBLIC_IP> ansible_user=ubuntu ansible_python_interpreter=/usr/bin/python3

[nfs_server]
db-server ansible_host=<DB_PUBLIC_IP> ansible_user=ubuntu ansible_python_interpreter=/usr/bin/python3

[all:vars]
ansible_ssh_private_key_file=~/.ssh/id_rsa
ansible_ssh_common_args='-o StrictHostKeyChecking=no -o UserKnownHostsFile=/dev/null'

# Private IPs for K8s configuration
# DB_PRIVATE_IP=<DB_PRIVATE_IP>
# NFS_SERVER_IP=<DB_PRIVATE_IP>
